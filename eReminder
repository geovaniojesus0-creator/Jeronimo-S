let reminders = [];
let currentView = 'today';
let editingId = null;

const STORAGE_KEY = 'eReminderData';

// Carregar dados
function loadReminders() {
    const saved = localStorage.getItem(STORAGE_KEY);
    reminders = saved ? JSON.parse(saved) : [];
    
    // Dados de exemplo (retrô edition)
    if (reminders.length === 0) {
        reminders = [
            {
                id: Date.now() - 86400000 * 2,
                title: "Reunião com a equipa de Luanda",
                notes: "Preparar apresentação do projeto Q3",
                due: "2026-03-25T14:30",
                completed: false,
                flagged: true,
                priority: 3,
                notified: false
            },
            {
                id: Date.now() - 86400000,
                title: "Comprar café na pastelaria",
                notes: "",
                due: "2026-03-24T08:00",
                completed: false,
                flagged: false,
                priority: 1,
                notified: false
            },
            {
                id: Date.now() - 3600000,
                title: "Enviar relatório ao cliente",
                notes: "Versão final com gráficos neon",
                due: "2026-03-26T11:00",
                completed: true,
                flagged: false,
                priority: 2,
                notified: true
            }
        ];
        saveReminders();
    }
}

function saveReminders() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(reminders));
}

// Formatar data (estilo Apple)
function formatDue(dueStr) {
    if (!dueStr) return '';
    const due = new Date(dueStr);
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    
    if (due < today) return `<span class="due-info overdue">Atrasado • ${due.toLocaleTimeString('pt-PT', {hour:'2-digit', minute:'2-digit'})}</span>`;
    
    const diffTime = due - today;
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    
    let label = '';
    if (diffDays === 0) label = 'Hoje';
    else if (diffDays === 1) label = 'Amanhã';
    else label = due.toLocaleDateString('pt-PT', {weekday: 'short'});
    
    return `<span class="due-info">${label} • ${due.toLocaleTimeString('pt-PT', {hour:'2-digit', minute:'2-digit'})}</span>`;
}

// Filtrar lembretes
function getFilteredReminders(view) {
    const now = new Date();
    const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const todayEnd = new Date(todayStart.getTime() + 86400000);
    
    let filtered = reminders.filter(r => {
        if (view === 'completed') return r.completed;
        return !r.completed;
    });
    
    switch (view) {
        case 'today':
            return filtered.filter(r => r.due && new Date(r.due) >= todayStart && new Date(r.due) < todayEnd);
        case 'scheduled':
            return filtered.filter(r => r.due);
        case 'flagged':
            return filtered.filter(r => r.flagged);
        case 'all':
            return filtered;
        default:
            return filtered;
    }
}

// Renderizar lista
function renderReminders() {
    const listEl = document.getElementById('reminders-list');
    listEl.innerHTML = '';
    
    const filtered = getFilteredReminders(currentView);
    const searchTerm = document.getElementById('search-input').value.toLowerCase().trim();
    
    const finalList = searchTerm 
        ? filtered.filter(r => r.title.toLowerCase().includes(searchTerm))
        : filtered;
    
    if (finalList.length === 0) {
        listEl.innerHTML = `<li style="text-align:center; padding:60px 20px; opacity:0.5; font-family:'VT323',monospace;">
            Nenhum lembrete aqui… ainda. ✨
        </li>`;
        return;
    }
    
    finalList.forEach(reminder => {
        const li = document.createElement('li');
        li.className = `reminder-item ${reminder.completed ? 'completed' : ''}`;
        li.innerHTML = `
            <input type="checkbox" ${reminder.completed ? 'checked' : ''}>
            <div class="title">${reminder.title}</div>
            ${reminder.due ? formatDue(reminder.due) : ''}
            ${reminder.flagged ? `<span class="flag">⭐</span>` : ''}
            ${reminder.priority > 0 ? `<span class="priority">${'！'.repeat(reminder.priority)}</span>` : ''}
        `;
        
        // Toggle completed
        li.querySelector('input[type="checkbox"]').addEventListener('click', (e) => {
            e.stopImmediatePropagation();
            toggleCompleted(reminder.id);
        });
        
        // Abrir modal ao clicar
        li.addEventListener('click', () => openModal(reminder.id));
        
        listEl.appendChild(li);
    });
    
    // Atualizar contador
    document.getElementById('count-badge').textContent = finalList.length;
}

// Alternar concluído
function toggleCompleted(id) {
    const reminder = reminders.find(r => r.id === id);
    if (reminder) {
        reminder.completed = !reminder.completed;
        saveReminders();
        renderReminders();
    }
}

// Modal
function openModal(id = null) {
    editingId = id;
    const modal = document.getElementById('modal');
    const form = document.getElementById('reminder-form');
    
    document.getElementById('modal-title-text').textContent = id ? 'Editar Lembrete' : 'Nova Lembrete';
    document.getElementById('delete-btn').style.display = id ? 'block' : 'none';
    
    if (id) {
        const r = reminders.find(rem => rem.id === id);
        document.getElementById('modal-title').value = r.title;
        document.getElementById('modal-notes').value = r.notes || '';
        document.getElementById('modal-due').value = r.due ? r.due.slice(0, 16) : '';
        document.getElementById('modal-priority').value = r.priority || 0;
        document.getElementById('modal-flagged').checked = r.flagged || false;
    } else {
        form.reset();
    }
    
    modal.style.display = 'flex';
}

// Fechar modal
function closeModal() {
    const modal = document.getElementById('modal');
    modal.style.display = 'none';
    editingId = null;
}

// Notificações do browser (igual Apple)
async function requestNotificationPermission() {
    if (Notification.permission === 'default') {
        await Notification.requestPermission();
    }
}

function showBrowserNotification(title) {
    if (Notification.permission === 'granted') {
        new Notification('🔔 eReminder', {
            body: `Está na hora de: ${title}`,
            icon: 'data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%27100%27 height=%27100%27 viewBox=%270 0 100 100%27%3E%3Crect width=%27100%27 height=%27100%27 rx=%2720%27 fill=%27%2300f7ff%27/%3E%3Ctext x=%2750%27 y=%2765%27 font-size=%2740%27 text-anchor=%27middle%27 fill=%27%23000%27%3E⏰%3C/text%3E%3C/svg%27',
            tag: 'ereminder-notification'
        });
    }
}

// Verificar lembretes em tempo real
function checkNotifications() {
    const now = new Date();
    reminders.forEach((r, index) => {
        if (!r.completed && r.due && !r.notified) {
            const dueDate = new Date(r.due);
            if (dueDate <= now) {
                showBrowserNotification(r.title);
                reminders[index].notified = true;
                saveReminders();
                renderReminders();
            }
        }
    });
}

// Inicialização
document.addEventListener('DOMContentLoaded', () => {
    loadReminders();
    
    // Render inicial
    renderReminders();
    
    // Sidebar navegação
    document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', () => {
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            item.classList.add('active');
            
            currentView = item.dataset.view;
            document.getElementById('current-list-title').textContent = item.textContent.trim();
            renderReminders();
        });
    });
    
    // Quick add
    const quickInput = document.getElementById('quick-title');
    quickInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && quickInput.value.trim()) {
            const newReminder = {
                id: Date.now(),
                title: quickInput.value.trim(),
                notes: '',
                due: '',
                completed: false,
                flagged: false,
                priority: 0,
                notified: false
            };
            reminders.unshift(newReminder);
            saveReminders();
            renderReminders();
            quickInput.value = '';
            
            // Toast retrô
            const toast = document.getElementById('toast');
            toast.textContent = '🚀 Lembrete adicionado!';
            toast.style.display = 'block';
            setTimeout(() => toast.style.display = 'none', 3000);
        }
    });
    
    // Modal events
    document.getElementById('reminder-form').addEventListener('submit', (e) => {
        e.preventDefault();
        
        const title = document.getElementById('modal-title').value.trim();
        if (!title) return;
        
        const dueValue = document.getElementById('modal-due').value;
        
        if (editingId) {
            const r = reminders.find(rem => rem.id === editingId);
            r.title = title;
            r.notes = document.getElementById('modal-notes').value;
            r.due = dueValue;
            r.priority = parseInt(document.getElementById('modal-priority').value);
            r.flagged = document.getElementById('modal-flagged').checked;
        } else {
            const newR = {
                id: Date.now(),
                title: title,
                notes: document.getElementById('modal-notes').value,
                due: dueValue,
                completed: false,
                flagged: document.getElementById('modal-flagged').checked,
                priority: parseInt(document.getElementById('modal-priority').value),
                notified: false
            };
            reminders.unshift(newR);
        }
        
        saveReminders();
        renderReminders();
        closeModal();
    });
    
    document.getElementById('close-modal').addEventListener('click', closeModal);
    document.getElementById('cancel-btn').addEventListener('click', closeModal);
    
    // Delete
    document.getElementById('delete-btn').addEventListener('click', () => {
        if (editingId && confirm('Eliminar esta lembrete para sempre?')) {
            reminders = reminders.filter(r => r.id !== editingId);
            saveReminders();
            renderReminders();
            closeModal();
        }
    });
    
    // Search live
    document.getElementById('search-input').addEventListener('input', renderReminders);
    
    // Pedir permissão de notificações
    requestNotificationPermission();
    
    // Verificar notificações a cada 30 segundos
    setInterval(checkNotifications, 30000);
    
    console.log('%c✅ eReminder carregado com sucesso! Design retrô-glass 100% Apple + único!', 'background:#00f7ff;color:#000;font-family:VT323;padding:4px 8px;border-radius:4px');
});</script>